# Uygulama adı (FastAPI başlığı)
APP_NAME="Smart Restaurant Finder API"

# CORS için izin verilen frontend kaynakları (virgülle ayrılır)
CORS_ORIGINS="http://localhost:5173"

# Google Places API (New) sunucu anahtarı (Google Cloud > Billing etkin + Places API New)
GOOGLE_MAPS_API_KEY=""

# Gemini AI asistanı anahtarı (ücretsiz: https://aistudio.google.com/apikey)
# Boş bırakılırsa /chat 503 döner; uygulama yine çalışır.
GEMINI_API_KEY=""
# (Opsiyonel) birincil model; yoğunlukta otomatik fallback yapılır
GEMINI_MODEL="gemini-2.5-flash"

# Veritabanı. Yerelde boş bırakılırsa SQLite kullanılır.
# Production (Neon): postgresql://kullanici:parola@host/dbname?sslmode=require
DATABASE_URL="sqlite:///./app.db"

# JWT imzalama anahtarı (production'da güçlü ve gizli bir değerle değiştir)
JWT_SECRET="dev-secret-change-me"
